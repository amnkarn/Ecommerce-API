generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {
  id                    String      @default(uuid())     @id
  username              String
  email                 String      @unique
  password              String
  verified              Boolean     @default(false)
  //otps                  Otp[]
  //session               Session[]
}
